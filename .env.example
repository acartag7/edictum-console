# Database (Postgres)
EDICTUM_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/edictum

# Redis
EDICTUM_REDIS_URL=redis://localhost:6379/0

# Secret key for session token signing (required, no default)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
EDICTUM_SECRET_KEY=

# Admin bootstrap (required on first run — creates admin user)
EDICTUM_ADMIN_EMAIL=admin@example.com
EDICTUM_ADMIN_PASSWORD=

# Auth provider (local is the only option for now)
EDICTUM_AUTH_PROVIDER=local

# Public base URL (for webhooks, CORS)
EDICTUM_BASE_URL=http://localhost:8000

# Session TTL in hours (default: 24)
EDICTUM_SESSION_TTL_HOURS=24

# Ed25519 signing-key encryption secret (32-byte hex string)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
EDICTUM_SIGNING_KEY_SECRET=

# CORS allowed origins (comma-separated)
EDICTUM_CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# Runtime environment (development | staging | production)
EDICTUM_ENV_NAME=development

# Telegram bot integration (optional — HITL approval notifications)
# EDICTUM_TELEGRAM_BOT_TOKEN=
# EDICTUM_TELEGRAM_CHAT_ID=0
# EDICTUM_TELEGRAM_WEBHOOK_SECRET=
