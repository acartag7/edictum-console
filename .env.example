# Edictum Console — Environment Configuration
# Copy this file to .env and fill in all required values.
#
#   cp .env.example .env
#
# Required secrets can be generated with:
#   python -c "import secrets; print(secrets.token_hex(32))"

# ── Required ──────────────────────────────────────────────

# Postgres password (used by both the postgres container and the server)
POSTGRES_PASSWORD=

# Secret key for session token signing
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
EDICTUM_SECRET_KEY=

# Ed25519 signing-key encryption secret (32 bytes = 64 hex chars)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
EDICTUM_SIGNING_KEY_SECRET=

# ── Admin Bootstrap (first run only) ─────────────────────

# Set these to auto-create the admin user on first startup.
# Alternatively, leave blank and use the /dashboard/setup wizard.
EDICTUM_ADMIN_EMAIL=
EDICTUM_ADMIN_PASSWORD=

# ── Optional ──────────────────────────────────────────────

# Public base URL — set to your domain in production (enables Secure cookies)
EDICTUM_BASE_URL=http://localhost:8000

# Auth provider (local is the only option for now)
EDICTUM_AUTH_PROVIDER=local

# Session TTL in hours (default: 24)
# EDICTUM_SESSION_TTL_HOURS=24

# CORS allowed origins (comma-separated)
# EDICTUM_CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# Runtime environment (development | staging | production)
# EDICTUM_ENV_NAME=development
